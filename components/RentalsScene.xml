<?xml version="1.0" encoding="utf-8"?>
<component name="RentalsScene" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/RentalsScene.brs" />
 
  <children>
    <Rectangle id="bg" width="1920" height="1080" color="0x121212FF" />

    <EmberTheme id="theme" />

    <Poster 
      id="headerLogo"
      translation="[30, 10]"
      width="650"
      height="180"
      loadDisplayMode="scaleToFit"
      uri="pkg:/images/logo/logo_header.png" />

    <Group translation="[960, 60]">
      <Label
        id="titleLabel"
        text="My Rentals"
        font="fontH1"
        color="0xFFFFFFFF"
        horizAlign="center"
        translation="[0,0]" />
      
      <Label
        id="subtitleLabel"
        text="Your active 48-hour rentals, ready to watch."
        font="fontSmall"
        color="0xAAAAAAFF"
        horizAlign="center"
        translation="[0, 70]" />
    </Group>

    <Group translation="[1450, 60]">
      <Group id="refreshBtn" focusable="true">
         <Rectangle id="refreshFill" width="180" height="60" color="0x2A2A2AFF" />
         <Label 
            id="refreshLabel"
            text="Refresh" 
            width="180" height="60" 
            horizAlign="center" vertAlign="center" 
            font="font:MediumBoldSystemFont" 
            color="0xFFFFFFFF" />
      </Group>

      <Group id="logoutBtn" translation="[220, 0]" focusable="true">
         <Rectangle id="logoutFill" width="180" height="60" color="0x2A2A2AFF" />
         <Label 
            id="logoutLabel"
            text="Sign Out" 
            width="180" height="60" 
            horizAlign="center" vertAlign="center" 
            font="font:MediumBoldSystemFont" 
            color="0xFFFFFFFF" />
      </Group>
    </Group>

    <Group id="focusedMetadata" translation="[80, 190]">
        <Label
            id="focusedTitle"
            text=""
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
            width="1000"
            height="50"
            wrap="false" />
    </Group>

    <MarkupGrid
      id="grid"
      translation="[80, 260]"
      itemSize="[270, 480]"
      itemSpacing="[40, 60]"
      numColumns="6"
      numRows="2"
      vertFocusAnimationStyle="fixedFocusWrap"
      drawFocusFeedback="false"
      itemComponentName="RentalGridItem" />

    <RentalsTask id="rentalsTask" />
  </children>

  <interface>
    <field id="authToken" type="string" />
    <field id="refreshNow" type="boolean" alwaysNotify="true" />
    <field id="selectedRental" type="node" alwaysNotify="true" />
    <field id="logoutRequested" type="boolean" alwaysNotify="true" />
  </interface>
</component>