<?xml version="1.0" encoding="utf-8"?>
<component name="RentalGridItem" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/RentalGridItem.brs" />

  <interface>
    <field id="itemContent" type="node" onChange="onItemContentChanged" />
    <field id="focusPercent" type="float" onChange="onFocusPercentChanged" />
  </interface>

  <children>
    
    <Group id="scaleGroup" scaleRotateCenter="[135, 202]">
        
        <Rectangle 
            id="focusRing"
            width="282" 
            height="417" 
            translation="[-6, -6]" 
            color="0xEBEBEBFF" 
            visible="false" />

        <Poster
          id="poster"
          width="270"
          height="405"
          translation="[0, 0]"
          loadDisplayMode="scaleToFit" />

    </Group>

    <Label
      id="expirationLabel"
      translation="[0, 420]"
      width="270"
      height="40"
      color="0xAAAAAAFF"
      horizAlign="center"
      vertAlign="top"
      wrap="false">
      <Font role="font" uri="font:SystemFont" size="20" />
    </Label>

    <Animation id="focusAnim" duration="0.15" easeFunction="outQuad">
        <Vector2DFieldInterpolator id="scaleInterp" 
            key="[0.0, 1.0]" 
            keyValue="[[1.0, 1.0], [1.06, 1.06]]" 
            fieldToInterp="scaleGroup.scale" />
    </Animation>

  </children>
</component>