<?xml version="1.0" encoding="utf-8"?>
<component name="LoginScene" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/LoginScene.brs" />

  <interface>
    <field id="loginSuccess" type="boolean" value="false" alwaysNotify="true" />
    <field id="authToken" type="string" value="" alwaysNotify="true" />
  </interface>

  <children>
    <LoginTask id="loginTask" />

    <Rectangle id="bg" width="1920" height="1080" color="0x000000FF" />

    <Timer id="focusTimer" duration="0.10" repeat="false" />

    <Group id="leftContent" translation="[130, 300]">
      
      <Poster id="logo" translation="[0, -40]" width="800" height="250" 
              loadDisplayMode="scaleToFit"
              uri="pkg:/images/logo/logo_header.png" />

      <Label id="title" translation="[0, 180]" width="920" height="80" 
             text="The way family movie nights should be." 
             color="0xFFFFFFFF" wrap="false" numLines="1"
             font="font:LargeBoldSystemFont" />
             
      <Label id="subtitle" translation="[0, 280]" width="850" height="100"
             text="Rent movies on the EmberTV web app and watch them instantly right here on your Roku." 
             color="0xAAAAAAFF" wrap="true" numLines="2"
             font="font:MediumSystemFont" />
    </Group>

    <Group id="form" translation="[1100, 300]">
      
      <Label id="formTitle" translation="[0, 0]" width="680" height="80" 
             text="Sign In" color="0xFFFFFFFF" font="font:LargeBoldSystemFont" />

      <Group id="emailField" translation="[0, 120]">
        <Rectangle id="emailBg" width="640" height="80" color="0x1A1A1AFF" />
        <Rectangle id="emailFocusBg" width="656" height="96" translation="[-8,-8]" color="0xEBEBEBFF" visible="true" />
        
        <Label id="emailValue" translation="[30, 20]" width="580" height="40" 
               text="Email Address" color="0x121212FF" font="font:MediumSystemFont" vertAlign="center" />
      </Group>

      <Group id="passField" translation="[0, 240]">
        <Rectangle id="passBg" width="640" height="80" color="0x1A1A1AFF" />
        <Rectangle id="passFocusBg" width="656" height="96" translation="[-8,-8]" color="0xEBEBEBFF" visible="false" />
        
        <Label id="passValue" translation="[30, 20]" width="580" height="40" 
               text="Password" color="0x888888FF" font="font:MediumSystemFont" vertAlign="center" />
      </Group>

      <Group id="signInBtn" translation="[0, 380]">
        <Rectangle id="btnBg" width="640" height="80" color="0x2A2A2AFF" />
        <Rectangle id="btnFocusBg" width="656" height="96" translation="[-8,-8]" color="0xEF6418FF" visible="false" />
        
        <Label id="btnText" translation="[0, 20]" width="640" height="40" horizAlign="center" 
               text="Log In" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" vertAlign="center" />
      </Group>
      
      <Label id="errorLabel" translation="[0, 500]" width="640" height="60" visible="false" 
             color="0xEF6418FF" wrap="true" numLines="2" horizAlign="center" font="font:MediumSystemFont" />

    </Group>
  </children>
</component>